DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scrum_game
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Development mode: database auth
AUTH_PROVIDER=database

# Later for LDAP/Active Directory
LDAP_SERVER=ldap://your-company-ad.local
LDAP_BASE_DN=DC=company,DC=local
LDAP_DOMAIN=company.local
